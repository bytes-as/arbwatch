# ============================================================
# predmkt-arb — environment variable reference
# Copy to .env (or .env.local) and fill in your values.
# preview.sh generates .env from this file automatically.
# ============================================================

# --- Database -----------------------------------------------
# SQLite (dev/preview): file path.  Neon (prod): postgres:// URL.
DATABASE_URL=file:./local.db

# --- Encryption ----------------------------------------------
# 32 random bytes encoded as base64.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The value below is a DETERMINISTIC PLACEHOLDER for local dev — never use in prod.
APP_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Next.js / NextAuth v5 -----------------------------------
# Secret used to sign session tokens.  Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-a-real-secret-for-production

# URL of the deployed app (used by NextAuth for callbacks).
# In development, next dev sets this automatically.
NEXTAUTH_URL=http://localhost:3000

# --- Wire integration ----------------------------------------
# WIRE_MODE=fixtures  → serve JSON fixtures from tests/fixtures/wire/ (local dev)
# WIRE_MODE=live      → call real Anakin Wire endpoints (production)
WIRE_MODE=fixtures

# --- Email (Resend) ------------------------------------------
# Required when WIRE_MODE=live and magic-link emails are sent.
# Not required when running in local/fixture mode.
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# --- Test-only flags -----------------------------------------
# Test only — never set in staging or production. Disables CSRF validation.
# SKIP_CSRF_CHECK=true
# Test only — never set in staging/prod. Enables /api/test-* routes.
# ENABLE_TEST_ROUTES=

# --- Vercel Cron authentication ------------------------------
# Random string used to authenticate the /api/cron/* routes.
# Set the same value in Vercel Dashboard → Settings → Environment Variables.
# CRON_SECRET=changeme-generate-a-real-secret
